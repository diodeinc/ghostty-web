diff --git a/src/terminal/c/web.zig b/src/terminal/c/web.zig
new file mode 100644
index 000000000..0a76208c2
--- /dev/null
+++ b/src/terminal/c/web.zig
@@ -0,0 +1,450 @@
+const std = @import("std");
+const color = @import("../color.zig");
+const modespkg = @import("../modes.zig");
+const terminal_c = @import("terminal.zig");
+const render_c = @import("render.zig");
+const Style = @import("../style.zig").Style;
+
+pub const GhosttyCell = extern struct {
+    codepoint: u32,
+    fg_r: u8,
+    fg_g: u8,
+    fg_b: u8,
+    bg_r: u8,
+    bg_g: u8,
+    bg_b: u8,
+    flags: u8,
+    width: u8,
+    hyperlink_id: u16,
+    grapheme_len: u8 = 0,
+    _pad: u8 = 0,
+};
+
+pub const GhosttyTerminalConfig = extern struct {
+    scrollback_limit: u32,
+    fg_color: u32,
+    bg_color: u32,
+    cursor_color: u32,
+    palette: [16]u32,
+};
+
+fn rgbFromU32(value: u32) color.RGB {
+    return .{
+        .r = @truncate((value >> 16) & 0xFF),
+        .g = @truncate((value >> 8) & 0xFF),
+        .b = @truncate(value & 0xFF),
+    };
+}
+
+fn rgbToU32(value: color.RGB) u32 {
+    return (@as(u32, value.r) << 16) | (@as(u32, value.g) << 8) | value.b;
+}
+
+fn defaultFg(wrapper: *const terminal_c.TerminalWrapper) color.RGB {
+    return wrapper.terminal.colors.foreground.get() orelse .{ .r = 0xFF, .g = 0xFF, .b = 0xFF };
+}
+
+fn defaultBg(wrapper: *const terminal_c.TerminalWrapper) color.RGB {
+    return wrapper.terminal.colors.background.get() orelse .{ .r = 0x00, .g = 0x00, .b = 0x00 };
+}
+
+fn cellFlags(sty: Style) u8 {
+    var flags: u8 = 0;
+    if (sty.flags.bold) flags |= 1 << 0;
+    if (sty.flags.italic) flags |= 1 << 1;
+    if (sty.flags.underline != .none) flags |= 1 << 2;
+    if (sty.flags.strikethrough) flags |= 1 << 3;
+    if (sty.flags.inverse) flags |= 1 << 4;
+    if (sty.flags.invisible) flags |= 1 << 5;
+    if (sty.flags.blink) flags |= 1 << 6;
+    if (sty.flags.faint) flags |= 1 << 7;
+    return flags;
+}
+
+pub fn newWithConfig(
+    cols: c_int,
+    rows: c_int,
+    config_: ?*const GhosttyTerminalConfig,
+) callconv(.c) ?*anyopaque {
+    if (cols <= 0 or rows <= 0) return null;
+
+    var init_opts = terminal_c.InitOptions{
+        .cols = @intCast(cols),
+        .rows = @intCast(rows),
+        .max_scrollback = 10_000,
+        .colors = .default,
+    };
+
+    if (config_) |cfg| {
+        init_opts.max_scrollback = if (cfg.scrollback_limit == 0)
+            std.math.maxInt(usize)
+        else
+            cfg.scrollback_limit;
+
+        if (cfg.fg_color != 0) init_opts.colors.foreground = color.DynamicRGB.init(rgbFromU32(cfg.fg_color));
+        if (cfg.bg_color != 0) init_opts.colors.background = color.DynamicRGB.init(rgbFromU32(cfg.bg_color));
+        if (cfg.cursor_color != 0) init_opts.colors.cursor = color.DynamicRGB.init(rgbFromU32(cfg.cursor_color));
+        for (cfg.palette, 0..) |palette_color, i| {
+            if (palette_color != 0) init_opts.colors.palette.set(@intCast(i), rgbFromU32(palette_color));
+        }
+    }
+
+    const wrapper = terminal_c.createWithInitOptions(null, init_opts) catch return null;
+    return @ptrCast(wrapper);
+}
+
+pub fn write(ptr: ?*anyopaque, data: [*]const u8, len: usize) callconv(.c) void {
+    const terminal: terminal_c.Terminal = @ptrCast(@alignCast(ptr));
+    terminal_c.vt_write(terminal, data, len);
+}
+
+pub fn getMode(ptr: ?*anyopaque, mode_num: c_int, is_ansi: bool) callconv(.c) bool {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return false));
+    const mode = modespkg.modeFromInt(@intCast(mode_num), is_ansi) orelse return false;
+    return wrapper.terminal.modes.get(mode);
+}
+
+pub fn isAlternateScreen(ptr: ?*anyopaque) callconv(.c) bool {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return false));
+    return wrapper.terminal.screens.active_key == .alternate;
+}
+
+pub fn hasMouseTracking(ptr: ?*anyopaque) callconv(.c) bool {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return false));
+    return wrapper.terminal.modes.get(.mouse_event_x10) or
+        wrapper.terminal.modes.get(.mouse_event_normal) or
+        wrapper.terminal.modes.get(.mouse_event_button) or
+        wrapper.terminal.modes.get(.mouse_event_any);
+}
+
+pub fn renderStateGetDirty(ptr: ?*anyopaque) callconv(.c) u8 {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return 2));
+    return switch (wrapper.state.dirty) {
+        .false => 0,
+        .partial => 1,
+        .full => 2,
+    };
+}
+
+pub fn renderStateGetCols(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    return @intCast(wrapper.state.cols);
+}
+
+pub fn renderStateGetRows(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    return @intCast(wrapper.state.rows);
+}
+
+pub fn renderStateGetCursorX(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    if (wrapper.state.cursor.viewport) |viewport| return @intCast(viewport.x);
+    return @intCast(wrapper.state.cursor.active.x);
+}
+
+pub fn renderStateGetCursorY(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    if (wrapper.state.cursor.viewport) |viewport| return @intCast(viewport.y);
+    return @intCast(wrapper.state.cursor.active.y);
+}
+
+pub fn renderStateGetCursorVisible(ptr: ?*anyopaque) callconv(.c) bool {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return false));
+    return wrapper.state.cursor.visible;
+}
+
+pub fn renderStateGetBgColor(ptr: ?*anyopaque) callconv(.c) u32 {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    return rgbToU32(wrapper.state.colors.background);
+}
+
+pub fn renderStateGetFgColor(ptr: ?*anyopaque) callconv(.c) u32 {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return 0xFFFFFF));
+    return rgbToU32(wrapper.state.colors.foreground);
+}
+
+pub fn renderStateIsRowDirty(ptr: ?*anyopaque, y: c_int) callconv(.c) bool {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return true));
+    if (y < 0) return false;
+    if (wrapper.state.dirty == .full) return true;
+    if (wrapper.state.dirty == .false) return false;
+    const idx: usize = @intCast(y);
+    if (idx >= wrapper.state.row_data.len) return false;
+    return wrapper.state.row_data.items(.dirty)[idx];
+}
+
+pub fn renderStateMarkClean(ptr: ?*anyopaque) callconv(.c) void {
+    const wrapper: *render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return));
+    wrapper.state.dirty = .false;
+    @memset(wrapper.state.row_data.items(.dirty), false);
+}
+
+pub fn renderStateGetViewport(
+    ptr: ?*anyopaque,
+    out: [*]GhosttyCell,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    const rows: usize = @intCast(wrapper.state.rows);
+    const cols: usize = @intCast(wrapper.state.cols);
+    const total = rows * cols;
+    if (buf_size < total) return -1;
+
+    const row_data = wrapper.state.row_data.slice();
+    const row_cells = row_data.items(.cells);
+
+    var idx: usize = 0;
+    for (0..rows) |y| {
+        for (0..cols) |x| {
+            const cell = row_cells[y].get(x);
+            const raw = cell.raw;
+            const sty: Style = if (raw.hasStyling()) cell.style else .{};
+            const fg = sty.fg(.{
+                .default = wrapper.state.colors.foreground,
+                .palette = &wrapper.state.colors.palette,
+            });
+            const bg = sty.bg(&raw, &wrapper.state.colors.palette) orelse wrapper.state.colors.background;
+
+            out[idx] = .{
+                .codepoint = if (raw.hasText()) raw.codepoint() else 0,
+                .fg_r = fg.r,
+                .fg_g = fg.g,
+                .fg_b = fg.b,
+                .bg_r = bg.r,
+                .bg_g = bg.g,
+                .bg_b = bg.b,
+                .flags = cellFlags(sty),
+                .width = switch (raw.wide) {
+                    .narrow => 1,
+                    .wide => 2,
+                    .spacer_head, .spacer_tail => 0,
+                },
+                .hyperlink_id = if (raw.hyperlink) 1 else 0,
+                .grapheme_len = @intCast(@min(cell.grapheme.len, 255)),
+            };
+            idx += 1;
+        }
+    }
+
+    return @intCast(total);
+}
+
+pub fn renderStateGetGrapheme(
+    ptr: ?*anyopaque,
+    row: c_int,
+    col: c_int,
+    out: [*]u32,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const wrapper: *const render_c.RenderStateWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    if (row < 0 or col < 0 or buf_size < 1) return -1;
+
+    const row_idx: usize = @intCast(row);
+    const col_idx: usize = @intCast(col);
+    if (row_idx >= wrapper.state.row_data.len) return -1;
+    if (col_idx >= @as(usize, @intCast(wrapper.state.cols))) return -1;
+
+    const cells = wrapper.state.row_data.items(.cells)[row_idx];
+    const cell = cells.get(col_idx);
+    if (!cell.raw.hasText()) return 0;
+
+    out[0] = cell.raw.codepoint();
+    var count: usize = 1;
+    for (cell.grapheme) |cp| {
+        if (count >= buf_size) break;
+        out[count] = cp;
+        count += 1;
+    }
+    return @intCast(count);
+}
+
+pub fn getScrollbackLength(ptr: ?*anyopaque) callconv(.c) c_int {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return 0));
+    const pages = &wrapper.terminal.screens.active.pages;
+    if (pages.total_rows <= pages.rows) return 0;
+    return @intCast(pages.total_rows - pages.rows);
+}
+
+pub fn getScrollbackLine(
+    ptr: ?*anyopaque,
+    offset: c_int,
+    out: [*]GhosttyCell,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    if (offset < 0) return -1;
+
+    const pages = &wrapper.terminal.screens.active.pages;
+    const cols: usize = @intCast(pages.cols);
+    if (buf_size < cols) return -1;
+    if (offset >= getScrollbackLength(ptr)) return -1;
+
+    const pin = pages.pin(.{ .history = .{ .y = @intCast(offset) } }) orelse return -1;
+    const cells = pin.cells(.all);
+    const page = pin.node.data;
+    const fg_default = defaultFg(wrapper);
+    const bg_default = defaultBg(wrapper);
+    const palette = &wrapper.terminal.colors.palette.current;
+
+    for (0..cols) |x| {
+        if (x >= cells.len) {
+            out[x] = .{
+                .codepoint = 0,
+                .fg_r = fg_default.r,
+                .fg_g = fg_default.g,
+                .fg_b = fg_default.b,
+                .bg_r = bg_default.r,
+                .bg_g = bg_default.g,
+                .bg_b = bg_default.b,
+                .flags = 0,
+                .width = 1,
+                .hyperlink_id = 0,
+            };
+            continue;
+        }
+
+        const raw = cells[x];
+        const sty: Style = if (raw.hasStyling())
+            page.styles.get(page.memory, raw.style_id).*
+        else
+            .{};
+        const fg = sty.fg(.{ .default = fg_default, .palette = palette });
+        const bg = sty.bg(&raw, palette) orelse bg_default;
+
+        out[x] = .{
+            .codepoint = if (raw.hasText()) raw.codepoint() else 0,
+            .fg_r = fg.r,
+            .fg_g = fg.g,
+            .fg_b = fg.b,
+            .bg_r = bg.r,
+            .bg_g = bg.g,
+            .bg_b = bg.b,
+            .flags = cellFlags(sty),
+            .width = switch (raw.wide) {
+                .narrow => 1,
+                .wide => 2,
+                .spacer_head, .spacer_tail => 0,
+            },
+            .hyperlink_id = if (raw.hyperlink) 1 else 0,
+            .grapheme_len = if (raw.hasGrapheme())
+                if (page.lookupGrapheme(&raw)) |cps| @intCast(@min(cps.len, 255)) else 0
+            else
+                0,
+        };
+    }
+
+    return @intCast(cols);
+}
+
+pub fn getScrollbackGrapheme(
+    ptr: ?*anyopaque,
+    offset: c_int,
+    col: c_int,
+    out: [*]u32,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    if (offset < 0 or col < 0 or buf_size < 1) return -1;
+    if (offset >= getScrollbackLength(ptr)) return -1;
+
+    const pin = wrapper.terminal.screens.active.pages.pin(.{ .history = .{ .y = @intCast(offset) } }) orelse return -1;
+    const cells = pin.cells(.all);
+    const page = pin.node.data;
+    const col_idx: usize = @intCast(col);
+    if (col_idx >= cells.len) return -1;
+
+    const cell = cells[col_idx];
+    if (!cell.hasText()) return 0;
+
+    out[0] = cell.codepoint();
+    var count: usize = 1;
+    if (cell.hasGrapheme()) {
+        if (page.lookupGrapheme(&cell)) |cps| {
+            for (cps) |cp| {
+                if (count >= buf_size) break;
+                out[count] = cp;
+                count += 1;
+            }
+        }
+    }
+    return @intCast(count);
+}
+
+pub fn isRowWrapped(ptr: ?*anyopaque, y: c_int) callconv(.c) bool {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return false));
+    if (y < 0) return false;
+    const pin = wrapper.terminal.screens.active.pages.pin(.{ .active = .{ .y = @intCast(y) } }) orelse return false;
+    return pin.rowAndCell().row.wrap_continuation;
+}
+
+fn copyHyperlinkUri(
+    cell: anytype,
+    page: anytype,
+    out: [*]u8,
+    buf_size: usize,
+) c_int {
+    if (!cell.hyperlink) return 0;
+    const hyperlink_id = page.lookupHyperlink(cell) orelse return 0;
+    const hyperlink_entry = page.hyperlink_set.get(page.memory, hyperlink_id);
+    const uri = hyperlink_entry.uri.slice(page.memory);
+    if (uri.len == 0) return 0;
+    if (buf_size < uri.len) return -1;
+    @memcpy(out[0..uri.len], uri);
+    return @intCast(uri.len);
+}
+
+pub fn getHyperlinkUri(
+    ptr: ?*anyopaque,
+    row: c_int,
+    col: c_int,
+    out: [*]u8,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    if (row < 0 or col < 0) return -1;
+    const pin = wrapper.terminal.screens.active.pages.pin(.{ .active = .{ .y = @intCast(row) } }) orelse return -1;
+    const cells = pin.cells(.all);
+    const col_idx: usize = @intCast(col);
+    if (col_idx >= cells.len) return -1;
+    const cell = &cells[col_idx];
+    return copyHyperlinkUri(cell, pin.node.data, out, buf_size);
+}
+
+pub fn getScrollbackHyperlinkUri(
+    ptr: ?*anyopaque,
+    offset: c_int,
+    col: c_int,
+    out: [*]u8,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    if (offset < 0 or col < 0) return -1;
+    if (offset >= getScrollbackLength(ptr)) return -1;
+    const pin = wrapper.terminal.screens.active.pages.pin(.{ .history = .{ .y = @intCast(offset) } }) orelse return -1;
+    const cells = pin.cells(.all);
+    const col_idx: usize = @intCast(col);
+    if (col_idx >= cells.len) return -1;
+    const cell = &cells[col_idx];
+    return copyHyperlinkUri(cell, pin.node.data, out, buf_size);
+}
+
+pub fn hasResponse(ptr: ?*anyopaque) callconv(.c) bool {
+    const wrapper: *const terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return false));
+    return wrapper.response_buffer.items.len > 0;
+}
+
+pub fn readResponse(ptr: ?*anyopaque, out: [*]u8, buf_size: usize) callconv(.c) c_int {
+    const wrapper: *terminal_c.TerminalWrapper = @ptrCast(@alignCast(ptr orelse return -1));
+    const len = @min(wrapper.response_buffer.items.len, buf_size);
+    if (len == 0) return 0;
+
+    @memcpy(out[0..len], wrapper.response_buffer.items[0..len]);
+    if (len == wrapper.response_buffer.items.len) {
+        wrapper.response_buffer.clearRetainingCapacity();
+    } else {
+        std.mem.copyForwards(u8, wrapper.response_buffer.items[0..], wrapper.response_buffer.items[len..]);
+        wrapper.response_buffer.shrinkRetainingCapacity(wrapper.response_buffer.items.len - len);
+    }
+
+    return @intCast(len);
+}
