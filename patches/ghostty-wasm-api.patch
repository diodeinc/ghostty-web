+    pub fn init(
+        alloc: std.mem.Allocator,
+        terminal: *ZigTerminal,
+        response_buffer: *std.ArrayList(u8),
+    ) ResponseHandler {
+        return .{
+            .alloc = alloc,
+            .base = .init(terminal),
+            .response_buffer = response_buffer,
+        };
+    }
+
+    pub fn deinit(self: *ResponseHandler) void {
+        self.base.deinit();
+    }
+
+    pub fn vt(
+        self: *ResponseHandler,
+        comptime action: Action.Tag,
+        value: Action.Value(action),
+    ) void {
+        switch (action) {
+            .device_status => self.handleDeviceStatus(value.request) catch |err| {
+                log.warn("error handling device status err={}", .{err});
+            },
+            .device_attributes => self.handleDeviceAttributes(value) catch |err| {
+                log.warn("error handling device attributes err={}", .{err});
+            },
+            else => self.base.vt(action, value),
+        }
+    }
+
+    fn handleDeviceStatus(self: *ResponseHandler, req: device_status.Request) !void {
+        const terminal = self.base.terminal;
+        switch (req) {
+            .operating_status => try self.response_buffer.appendSlice(self.alloc, "\x1B[0n"),
+            .cursor_position => {
+                const cursor = terminal.screens.active.cursor;
+                const x = if (terminal.modes.get(.origin))
+                    cursor.x -| terminal.scrolling_region.left
+                else
+                    cursor.x;
+                const y = if (terminal.modes.get(.origin))
+                    cursor.y -| terminal.scrolling_region.top
+                else
+                    cursor.y;
+                var buf: [32]u8 = undefined;
+                const resp = std.fmt.bufPrint(&buf, "\x1B[{};{}R", .{
+                    y + 1,
+                    x + 1,
+                }) catch return;
+                try self.response_buffer.appendSlice(self.alloc, resp);
+            },
+            .color_scheme => {},
+        }
+    }
+
+    fn handleDeviceAttributes(self: *ResponseHandler, req: ansi.DeviceAttributeReq) !void {
+        switch (req) {
+            .primary => try self.response_buffer.appendSlice(self.alloc, "\x1B[?62;22c"),
+            .secondary => try self.response_buffer.appendSlice(self.alloc, "\x1B[>1;10;0c"),
+            else => {},
+        }
+    }
+};
